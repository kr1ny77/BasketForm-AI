# Environment Variables Configuration
# Copy this file to .env and fill in the values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/basketformai
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=basketformai
DATABASE_USERNAME=username
DATABASE_PASSWORD=password

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRATION=900
REFRESH_TOKEN_EXPIRATION=604800

# File Storage (AWS S3)
AWS_S3_BUCKET=basketformai-videos
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# API Configuration
API_KEY=your-api-key-here
API_RATE_LIMIT=100
API_TIMEOUT=30000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=BasketForm-AI

# Backend Configuration
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Video Processing
MAX_FILE_SIZE=104857600
ALLOWED_VIDEO_FORMATS=mp4,mov,avi
PROCESSING_TIMEOUT=60000

# Email (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password

# Analytics (optional)
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=your-tracking-id

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# External Services
MEDIAPIPE_MODEL_PATH=./models/pose_landmark_heavy.tflite
OPENAI_API_KEY=your-openai-api-key